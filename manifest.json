{
    "manifest_version": 3,
    "name": "FB 社團篩選器",
    "version": "1.0.0",
    "description": "只看你想看的 Facebook 社團貼文，按時間排序",
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://www.facebook.com/*",
        "https://m.facebook.com/*",
        "https://discord.com/api/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.facebook.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ]
}